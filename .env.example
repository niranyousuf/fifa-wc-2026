# Required on Vercel (and optional GitHub Actions secret with the same name)
ZAFRONIX_API_KEY=your_zafronix_api_key_here

# Optional locally/Vercel only: extra keys when the primary hits 429 (not needed for GitHub Actions)
# ZAFRONIX_API_KEYS=your_second_key

WC_YEAR=2026
# Used for Open Graph / social share previews (set to your production URL on Vercel)
NEXT_PUBLIC_APP_URL=https://fifa-wc-2026-alpha.vercel.app

# Optional Vercel cron backup (primary refresh is GitHub Actions every 6h)
# CRON_SECRET=your_random_secret_here
